  {
    "id": 5,
    "title": "Short Vowels — Harakat",
    "urdu_title": "حرکات — زبر، زیر، پیش",
    "description": "The three short vowel marks that give sound to a letter.",
    "type": "harakat",
    "examples": [
      { "arabic": "بَ", "name": "Fatha (Zabar)", "urdu": "زبر", "sound": "ba", "color": "#E74C3C", "desc": "Small diagonal stroke above — adds 'a' sound" },
      { "arabic": "بِ", "name": "Kasra (Zer)", "urdu": "زیر", "sound": "bi", "color": "#3498DB", "desc": "Small stroke below — adds 'i' sound" },
      { "arabic": "بُ", "name": "Damma (Pesh)", "urdu": "پیش", "sound": "bu", "color": "#27AE60", "desc": "Small waw-like symbol above — adds 'u' sound" }
    ],
    "practice": [
      { "arabic": "بَ تَ ثَ جَ حَ خَ", "label": "With Fatha" },
      { "arabic": "بِ تِ ثِ جِ حِ خِ", "label": "With Kasra" },
      { "arabic": "بُ تُ ثُ جُ حُ خُ", "label": "With Damma" }
    ],
    "quiz": true
  },
  {
    "id": 6,
    "title": "Tanween — Double Vowels",
    "urdu_title": "تنوین",
    "description": "Double harakat at the end of a word — adds 'n' sound after the vowel.",
    "type": "harakat",
    "examples": [
      { "arabic": "بًا", "name": "Tanween Fath", "urdu": "دو زبر", "sound": "ban", "color": "#E74C3C", "desc": "Two fathas — sounds like 'an'" },
      { "arabic": "بٍ", "name": "Tanween Kasr", "urdu": "دو زیر", "sound": "bin", "color": "#3498DB", "desc": "Two kasras — sounds like 'in'" },
      { "arabic": "بٌ", "name": "Tanween Damm", "urdu": "دو پیش", "sound": "bun", "color": "#27AE60", "desc": "Two dammas — sounds like 'un'" }
    ],
    "practice": [
      { "arabic": "كِتَابًا", "label": "Tanween Fath — kitaaban (a book)" },
      { "arabic": "مُسْلِمٍ", "label": "Tanween Kasr — muslimin (of a Muslim)" },
      { "arabic": "رَجُلٌ", "label": "Tanween Damm — rajulun (a man)" }
    ],
    "quiz": true
  },
  {
    "id": 7,
    "title": "Sukoon — No Vowel",
    "urdu_title": "سکون — جزم",
    "description": "A small circle above a letter — means that letter has no vowel. Its sound is cut short.",
    "type": "harakat",
    "examples": [
      { "arabic": "بْ", "name": "Ba with Sukoon", "sound": "b (stopped)", "color": "#8E44AD", "desc": "The 'b' sound ends here — no vowel follows from this letter" },
      { "arabic": "مْ", "name": "Meem with Sukoon", "sound": "m (stopped)", "color": "#8E44AD", "desc": "Lips close for meem then stop" },
      { "arabic": "نْ", "name": "Noon with Sukoon", "sound": "n (nasal)", "color": "#8E44AD", "desc": "Subject to Tajweed rules (idgham, ikhfa etc.)" }
    ],
    "practice": [
      { "arabic": "بِسْمِ", "label": "Bismi — seen has sukoon" },
      { "arabic": "الْحَمْدُ", "label": "Alhamdu — lam and meem have sukoon" },
      { "arabic": "مُسْلِم", "label": "Muslim — seen has sukoon" }
    ],
    "quiz": false
  },
  {
    "id": 8,
    "title": "Shaddah — Double Letter",
    "urdu_title": "شدّہ — تشدید",
    "description": "A small 'w'-shaped mark above a letter. It means the letter is doubled — pronounced twice as long.",
    "type": "harakat",
    "examples": [
      { "arabic": "بَّ", "name": "Ba with Shaddah", "sound": "bba", "color": "#D35400", "desc": "As if two ba's — first with sukoon, second with fatha" },
      { "arabic": "مَّ", "name": "Meem with Shaddah", "sound": "mma", "color": "#D35400", "desc": "Hold the meem sound — ghunnah applies" },
      { "arabic": "نَّ", "name": "Noon with Shaddah", "sound": "nna", "color": "#D35400", "desc": "Ghunnah — nasal sound for 2 counts" }
    ],
    "practice": [
      { "arabic": "اللَّه", "label": "Allah — lam has shaddah" },
      { "arabic": "إِنَّ", "label": "Inna — noon has shaddah (ghunnah)" },
      { "arabic": "رَبَّنَا", "label": "Rabbana — ba has shaddah" }
    ],
    "quiz": false
  },
  {
    "id": 9,
    "title": "Madd — Long Vowels",
    "urdu_title": "مدّ — لمبی آواز",
