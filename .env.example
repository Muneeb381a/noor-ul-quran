# ─── SERVER environment variables ────────────────────────────────────────────
# Set these in Vercel dashboard → Server project → Environment Variables
# Local dev: copy to server/.env

DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
JWT_SECRET=generate_a_long_random_string_min_64_chars
JWT_EXPIRES=7d
PORT=5000
CLIENT_URL=https://noor-ul-quran-h7vd.vercel.app
NODE_ENV=production

# ─── CLIENT environment variables ────────────────────────────────────────────
# Set this in Vercel dashboard → Client project → Environment Variables
# Local dev: leave empty — Vite proxy handles /api → localhost:5000

VITE_API_URL=https://noor-ul-quran-alpha.vercel.app
