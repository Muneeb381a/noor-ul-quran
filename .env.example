# ─── SERVER environment variables ────────────────────────────────────────────
# Copy to server/.env and fill in real values

DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
JWT_SECRET=generate_a_long_random_string_min_64_chars
JWT_EXPIRES=7d
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ─── CLIENT environment variables ────────────────────────────────────────────
# Copy to client/.env and set for production
# For local dev leave empty — Vite proxy handles /api → localhost:5000
# For Vercel production set to your server deployment URL:
#   VITE_API_URL=https://noor-ul-quran-server.vercel.app

VITE_API_URL=
